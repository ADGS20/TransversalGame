{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "81084cb933ea4fdaa1f5976982fb07a2",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "SistemaMagia (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -1247.3333740234375,
            "y": -254.66665649414063,
            "width": 262.6666259765625,
            "height": 222.66665649414063
        }
    },
    "m_Slots": [
        {
            "m_Id": "e55a04a0cb5841ba8e33fd899cc4d844"
        },
        {
            "m_Id": "51982cb71e7d4331841b2202b931b93b"
        },
        {
            "m_Id": "ca82b26c08824fafbc31c82f7b59d8bf"
        },
        {
            "m_Id": "46e849641a4f4c1491b3b8abae01553d"
        },
        {
            "m_Id": "660dd2795589492b91fbc46c6913e667"
        },
        {
            "m_Id": "ef608bdd6089490e83dcf5d80710fad1"
        },
        {
            "m_Id": "3307cae188f24649aed38dbd204f66c7"
        },
        {
            "m_Id": "4f6662a4604e4069943146d20308743a"
        },
        {
            "m_Id": "4aca3d2d3106474abaeeaa9672129942"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "SistemaMagia",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float dist = distance(WorldPos, CentroOnda);\r\nfloat inside = (dist <= RadioOnda) ? 1.0 : 0.0;\r\nfloat outside = 1.0 - inside;\r\n\r\nfloat esVisible = 1.0;\r\nfloat pintarLaser = 0.0;\r\n\r\n// REGLAS ESTRICTAS DE TUS LISTAS (0, 1, 2, 3) + MODO NORMAL (4):\r\nif (TipoObjeto < 0.5) {\r\n    if (OndaEsV > 0.5) { esVisible = inside; pintarLaser = 1.0; } else { esVisible = 0.0; }\r\n} else if (TipoObjeto < 1.5) {\r\n    if (OndaEsV > 0.5) { esVisible = outside; pintarLaser = 1.0; } else { esVisible = 1.0; }\r\n} else if (TipoObjeto < 2.5) {\r\n    if (OndaEsV < 0.5) { esVisible = inside; pintarLaser = 1.0; } else { esVisible = 0.0; }\r\n} else if (TipoObjeto < 3.5) {\r\n    if (OndaEsV < 0.5) { esVisible = outside; pintarLaser = 1.0; } else { esVisible = 1.0; }\r\n} else {\r\n    // 4 o más: NORMAL (Ignora la onda, no tiene láser y siempre es visible)\r\n    esVisible = 1.0;\r\n    pintarLaser = 0.0;\r\n}\r\n\r\nMultiplicadorAlpha = esVisible;\r\n\r\nif (pintarLaser > 0.5 && abs(dist - RadioOnda) < GrosorLaser && RadioOnda > 0.1) {\r\n    EmisionLaser = ColorLaser;\r\n} else {\r\n    EmisionLaser = float3(0, 0, 0);\r\n}"
}

