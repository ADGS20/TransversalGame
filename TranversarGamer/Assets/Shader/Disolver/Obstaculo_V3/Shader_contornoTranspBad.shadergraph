        {
            "m_Id": "2820b67e840345bda69415ae60a6fd05"
        },
        {
            "m_Id": "043f971c26fd4ea19fbcec16d007f4e7"
        },
        {
            "m_Id": "da6db2740f0e4a8492d43406844af68c"
        },
        {
            "m_Id": "00083cccbeda4c2fb605949db7995198"
        },
        {
            "m_Id": "4310ed99a394431cba66576b762168ed"
        },
        {
            "m_Id": "4c1bf0d08ec94ad5b44a6585013adc07"
        },
        {
            "m_Id": "99a88b8c82c54134971e71bdd4c25a47"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "SistemaMagia",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float dist = distance(WorldPos, CentroOnda);\r\nfloat inside = (dist <= RadioOnda) ? 1.0 : 0.0;\r\nfloat outside = 1.0 - inside;\r\n\r\nfloat esVisible = 0.0;\r\nfloat pintarLaser = 0.0;\r\n\r\n// REGLAS ESTRICTAS DE TUS LISTAS (0, 1, 2, 3):\r\nif (TipoObjeto < 0.5) {\r\n    if (OndaEsV > 0.5) { esVisible = inside; pintarLaser = 1.0; } else { esVisible = 0.0; }\r\n} else if (TipoObjeto < 1.5) {\r\n    if (OndaEsV > 0.5) { esVisible = outside; pintarLaser = 1.0; } else { esVisible = 1.0; }\r\n} else if (TipoObjeto < 2.5) {\r\n    if (OndaEsV < 0.5) { esVisible = inside; pintarLaser = 1.0; } else { esVisible = 0.0; }\r\n} else {\r\n    if (OndaEsV < 0.5) { esVisible = outside; pintarLaser = 1.0; } else { esVisible = 1.0; }\r\n}\r\n\r\nMultiplicadorAlpha = esVisible;\r\n\r\nif (pintarLaser > 0.5 && abs(dist - RadioOnda) < GrosorLaser && RadioOnda > 0.1) {\r\n    EmisionLaser = ColorLaser;\r\n} else {\r\n    EmisionLaser = float3(0, 0, 0);\r\n}"
}

