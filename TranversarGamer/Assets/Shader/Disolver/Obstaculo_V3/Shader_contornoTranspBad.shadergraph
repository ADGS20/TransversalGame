    },
    "m_Name": "SistemaMagia (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -688.0000610351563,
            "y": 449.3333435058594,
            "width": 262.6666564941406,
            "height": 240.00009155273438
        }
    },
    "m_Slots": [
